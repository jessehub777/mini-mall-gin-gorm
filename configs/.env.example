# 应用配置
APP_NAME=mini-mall-gin-gorm
APP_PORT=8080
# API 路由前缀：可选 /api、/api/v1、空字符串（不加前缀）
APP_API_PREFIX=/api

# MySQL 8.0 配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=mini_mall
DB_CHARSET=utf8mb4
DB_PARSE_TIME=True
DB_LOC=Local

# JWT 配置
JWT_SECRET=please-change-me
JWT_EXPIRE_HOURS=24
